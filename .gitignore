# On-demand FIDO2 source clones (build-libfido2.sh)
vendor_c/yubico/
vendor_c/madler/
vendor_c/openssl/
*.tmp
*.swp
.vscode/
.idea/
*.bak
*.old
.env
secrets.env
build/
