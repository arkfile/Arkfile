# Arkfile Caddyfile - Generic Production Reference
# This is a clean reference template for future production deployment work.
# For test deployments, see Caddyfile.test (used by scripts/test-deploy.sh).
# For local deployments, see Caddyfile.local (reference only, not used by local-deploy.sh).

{
	# Set your ACME email for Let's Encrypt expiration notices
	# email you@example.com

	servers {
		protocols h1 h2 h3
		strict_sni_host
	}
}

# Replace with your actual domain
your.domain.example {
	tls {
		# Configure DNS challenge for your DNS provider, e.g.:
		# dns desec {
		#     token {$DESEC_TOKEN}
		# }
		# dns cloudflare {$CLOUDFLARE_API_TOKEN}
		protocols tls1.3
		key_type p384
	}

	header {
		# HSTS: Caddy owns TLS termination so it is the right place for this header.
		# All other security headers (CSP, X-Frame-Options, etc.) are set by the
		# Go application's middleware and must NOT be duplicated here.
		# Duplicate CSP headers cause browsers to enforce the intersection of both,
		# breaking features like TOTP QR codes (data: URI images).
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
	}

	reverse_proxy localhost:8443 {
		transport http {
			tls
			tls_insecure_skip_verify
		}
		health_uri /readyz
		health_interval 30s
		health_timeout 10s
		health_status 200
	}

	encode gzip

	log {
		output file /var/log/caddy/access.log
		format json
	}

	handle_errors {
		respond "{http.error.status_code} {http.error.status_text}"
	}
}
