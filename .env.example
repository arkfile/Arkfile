# .env.example
# Template for Arkfile deployment configuration.
# Copy relevant sections to /opt/arkfile/etc/secrets.env and fill in real values.
# Never commit actual secrets or credentials to version control.

# Application Environment
# Controls production safety checks. Set to 'production' or 'prod' for live deployments.
ENVIRONMENT=development

# Domain Configuration
DOMAIN=example.com

# Service Configuration
PORT=8080
CORS_ALLOWED_ORIGINS=https://localhost:8443

# rqlite Database Configuration
RQLITE_ADDRESS=http://localhost:4001
RQLITE_USERNAME=local-user
RQLITE_PASSWORD=your_secret_here

# JWT Token Lifetime (default: 30 minutes)
JWT_TOKEN_LIFETIME_MINUTES=30

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================

# Admin username(s) for this instance (comma-separated if multiple).
# Set this to the username(s) you will use when bootstrapping the admin account.
# The application will BLOCK dev admin accounts (arkfile-dev-admin, test-admin,
# dev-admin) in production environments.
ADMIN_USERNAMES=your-admin-username

# Admin contact email shown to pending users on the awaiting-approval screen.
# If not set, no contact address is displayed to pending users.
ARKFILE_ADMIN_CONTACT=admin@your-domain.example

# Dev/Test API endpoints (MUST be false in production)
ADMIN_DEV_TEST_API_ENABLED=false

# Require admin approval for new user accounts
REQUIRE_APPROVAL=true

# Admin bootstrap mode (set to true for first-time setup, false after bootstrapping)
ARKFILE_FORCE_ADMIN_BOOTSTRAP=false

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# Supported providers: generic-s3, backblaze, cloudflare-r2, wasabi, vultr, aws-s3

STORAGE_PROVIDER=generic-s3

# Generic S3 / local SeaweedFS
S3_ENDPOINT=http://localhost:9332
S3_ACCESS_KEY=arkfile-local
S3_SECRET_KEY=your_secret_here
S3_BUCKET=arkfile-local
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false

# Amazon S3 (when STORAGE_PROVIDER=aws-s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET_NAME=your-bucket-name

# Backblaze B2 (when STORAGE_PROVIDER=backblaze)
# BACKBLAZE_ENDPOINT=s3.us-west-004.backblazeb2.com
# BACKBLAZE_KEY_ID=your_key_id
# BACKBLAZE_APPLICATION_KEY=your_application_key
# BACKBLAZE_BUCKET_NAME=your-bucket-name

# Cloudflare R2 (when STORAGE_PROVIDER=cloudflare-r2)
# CLOUDFLARE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# CLOUDFLARE_ACCESS_KEY_ID=your_access_key_id
# CLOUDFLARE_SECRET_ACCESS_KEY=your_secret_access_key
# CLOUDFLARE_BUCKET_NAME=your-bucket-name

# Wasabi (when STORAGE_PROVIDER=wasabi)
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=your-bucket-name

# Vultr Object Storage (when STORAGE_PROVIDER=vultr)
# S3_REGION=ewr
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=your-bucket-name

# Optional: Human-readable provider ID (auto-generated as "type:bucket" if not set)
# STORAGE_PROVIDER_ID=seaweedfs-local

# ============================================================================
# MULTI-BACKEND STORAGE (Optional)
# ============================================================================
# Up to 3 providers can be configured. Secondary and tertiary are optional.
# When no secondary is configured, the system operates in single-provider mode.

# Secondary provider (automatic replication target, download fallback)
# STORAGE_PROVIDER_2=wasabi
# STORAGE_PROVIDER_2_ID=wasabi-us-central-1
# STORAGE_2_ENDPOINT=https://s3.us-central-1.wasabisys.com
# STORAGE_2_ACCESS_KEY=your_access_key
# STORAGE_2_SECRET_KEY=your_secret_key
# STORAGE_2_BUCKET=arkfile-backup
# STORAGE_2_REGION=us-central-1
# STORAGE_2_FORCE_PATH_STYLE=true

# Tertiary provider (manual copy target only, third-tier download fallback)
# Requires a secondary provider to be configured.
# STORAGE_PROVIDER_3=backblaze
# STORAGE_PROVIDER_3_ID=backblaze-us-west
# STORAGE_3_ENDPOINT=s3.us-west-004.backblazeb2.com
# STORAGE_3_ACCESS_KEY=your_key_id
# STORAGE_3_SECRET_KEY=your_application_key
# STORAGE_3_BUCKET=arkfile-archive
# STORAGE_3_REGION=us-west-004
# STORAGE_3_FORCE_PATH_STYLE=false

# Automatic replication of uploads to secondary provider (default: false)
# ENABLE_UPLOAD_REPLICATION=false

# ============================================================================
# TLS CONFIGURATION
# ============================================================================

TLS_ENABLED=true
TLS_PORT=8443
TLS_CERT_FILE=/opt/arkfile/etc/keys/tls/arkfile/server.crt
TLS_KEY_FILE=/opt/arkfile/etc/keys/tls/arkfile/server.key

# For test deployments using Caddy + deSEC DNS challenge:
# DESEC_TOKEN=your_desec_api_token
# CADDY_EMAIL=your-email@example.com

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=info
DEBUG_MODE=false
ENABLE_REGISTRATION=true
